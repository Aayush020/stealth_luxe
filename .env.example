# Copy this file to `.env` and fill in real values before running locally
# or deploying. Never commit the real `.env` file.

# A long, random string used to sign session cookies.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string

# "production" disables Flask debug mode. Use "development" locally if you
# want auto-reload and full tracebacks.
FLASK_ENV=development

# Port the app listens on. Most hosts (Render, Railway, etc.) inject their
# own PORT env var automatically — this is just the local default.
PORT=5000

# Path to the SQLite database file. Defaults to stealth_luxe.db next to
# app.py if not set. On most hosts, point this at a persistent disk/volume
# so data survives redeploys (see README's "Deployment" section).
DATABASE_PATH=stealth_luxe.db
